<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Acceso Seguro | CRM Pro</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }
        body {
            /* Fondo corporativo profundo y elegante */
            background-color: #0f172a; 
            background-image: radial-gradient(circle at top right, #1e293b, #0f172a);
            display: flex; align-items: center; justify-content: center; height: 100vh;
            color: #0f172a;
        }
        .login-wrapper {
            width: 100%; max-width: 420px; padding: 20px;
        }
        .brand-header {
            text-align: center; margin-bottom: 30px; color: white;
        }
        .brand-header h1 { font-size: 2rem; font-weight: 700; letter-spacing: -0.02em; }
        .brand-header span { color: #4f46e5; }
        .brand-header p { color: #94a3b8; font-size: 0.9rem; margin-top: 5px; }
        
        .login-card {
            background: #ffffff;
            padding: 40px; 
            border-radius: 16px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255,255,255,0.1);
        }
        .input-group { margin-bottom: 20px; }
        .input-group label { display: block; margin-bottom: 8px; font-weight: 500; font-size: 0.9rem; color: #334155; }
        .input-group input {
            width: 100%; padding: 12px 16px; border-radius: 8px; border: 1px solid #cbd5e1;
            font-size: 1rem; transition: all 0.2s ease; outline: none; background: #f8fafc;
        }
        .input-group input:focus { border-color: #4f46e5; background: #ffffff; box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1); }
        
        .btn-primary {
            background-color: #4f46e5; color: white; border: none; width: 100%;
            padding: 12px; border-radius: 8px; font-weight: 600; font-size: 1rem;
            cursor: pointer; transition: all 0.2s ease; display: flex; justify-content: center; align-items: center; gap: 8px;
            box-shadow: 0 4px 6px -1px rgba(79, 70, 229, 0.2);
        }
        .btn-primary:hover { background-color: #4338ca; transform: translateY(-1px); box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.3); }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="brand-header">
            <i class="fa-solid fa-chart-pie" style="font-size: 2.5rem; color: #4f46e5; margin-bottom: 10px;"></i>
            <h1>CRM<span>Pro</span></h1>
            <p>Panel de Control B2B</p>
        </div>
        <div class="login-card">
            <form id="loginForm">
                <div class="input-group">
                    <label>Correo Electrónico Corporativo</label>
                    <input type="email" id="email" required placeholder="tu@empresa.com">
                </div>
                <div class="input-group">
                    <label>Contraseña de Acceso</label>
                    <input type="password" id="password" required placeholder="••••••••">
                </div>
                <button type="submit" class="btn-primary">Ingresar al Sistema <i class="fa-solid fa-arrow-right"></i></button>
            </form>
        </div>
    </div>
    
    <script type="module">
        import { api } from './js/core/api.js';
        document.getElementById('loginForm').onsubmit = async (e) => {
            e.preventDefault();
            const btn = e.target.querySelector('button');
            btn.innerHTML = 'Verificando...';
            btn.style.opacity = '0.7';

            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;

            try {
                const res = await api.login(email, password);
                if (res.status === 200) { window.location.href = 'index.html'; }
            } catch (error) {
                alert("Error de autenticación: Verifica tus credenciales.");
                btn.innerHTML = 'Ingresar al Sistema <i class="fa-solid fa-arrow-right"></i>';
                btn.style.opacity = '1';
            }
        };
    </script>
</body>
</html>